# Backend Environment Variables for Railway
# Copy this file as .env and fill in your values

# ===================
# SECURITY
# ===================
SECRET_KEY=generate-a-secure-random-string-here

# ===================
# DATABASE (PostgreSQL recommended for production)
# ===================
# For Railway PostgreSQL, use format:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./real_estate.db

# ===================
# STRIPE PAYMENTS
# ===================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Create prices in Stripe Dashboard > Products
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxx
STRIPE_INVESTOR_PRICE_ID=price_xxxxxxxxxxxxxx

# ===================
# RENTCAST API (Real Property Data)
# ===================
# Get from https://www.rentcast.io/pricing
RENTCAST_API_KEY=your_rentcast_api_key

# ===================
# FRONTEND URL (For CORS & Redirects)
# ===================
FRONTEND_URL=https://your-frontend.vercel.app
